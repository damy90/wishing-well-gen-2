# Copy to .env for local development

# Base path for GitHub Pages build (default /wishing-well-gen-2/)
# GITHUB_PAGES_BASE=/wishing-well-gen-2/

# Static assets origin (greeting.json, success.jpeg, logo)
# VITE_SERVER_BASE_URL=https://damy90.github.io/wishing-well-gen-2

# Receive API origin (Node server — npm run server)
VITE_API_BASE_URL=http://localhost:3001
