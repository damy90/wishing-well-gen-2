# GitHub Pages base path (project site). Include leading and trailing slashes.
GITHUB_PAGES_BASE=/wishing-well-gen-2/

# Full origin of your GitHub Pages deployment (no trailing slash).
# Required for build:facebook so the Instant Game fetches logo + greeting from GitHub Pages.
VITE_SERVER_BASE_URL=https://YOUR_USER.github.io/wishing-well-gen-2
